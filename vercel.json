{
  "version": 2,
  "name": "elenice-collection",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/catalogo", "destination": "/catalogo.html" },
    { "source": "/produto", "destination": "/produto.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/rastreio", "destination": "/rastreio.html" },
    { "source": "/sobre", "destination": "/sobre.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/dashboard", "destination": "/admin/dashboard.html" },
    { "source": "/admin/produto", "destination": "/admin/produto.html" },
    { "source": "/admin/cupons", "destination": "/admin/cupons.html" },
    { "source": "/admin/configuracoes", "destination": "/admin/configuracoes.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}