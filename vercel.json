{
  "version": 2,
  "name": "selene-joias",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/catalogo", "dest": "/catalogo.html" },
    { "src": "/produto", "dest": "/produto.html" },
    { "src": "/checkout", "dest": "/checkout.html" },
    { "src": "/rastreio", "dest": "/rastreio.html" },
    { "src": "/sobre", "dest": "/sobre.html" },
    { "src": "/admin", "dest": "/admin/index.html" },
    { "src": "/admin/", "dest": "/admin/index.html" },
    { "src": "/admin/dashboard", "dest": "/admin/dashboard.html" },
    { "src": "/admin/produto", "dest": "/admin/produto.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
